<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="900" height="500">
  <style>
    .bg{fill:#f6f8fb}
    .card{fill:#ffffff;stroke:#e1e6ef;stroke-width:1;filter:drop-shadow(0 2px 6px rgba(16,24,40,0.08));}
    .title{font:700 24px/1.2 'Segoe UI', Roboto, sans-serif; fill:#0f172a}
    .item{font:400 18px/1.3 'Segoe UI', Roboto, sans-serif; fill:#0f172a}
    .new{font:600 18px/1.3 'Segoe UI', Roboto, sans-serif; fill:#065f46}
    .badge{fill:#d1fae5;stroke:#10b981;stroke-width:0}
  </style>
  <rect class="bg" width="100%" height="100%"/>
  <g transform="translate(40,30)">
    <rect class="card" x="0" y="0" rx="10" ry="10" width="820" height="420"/>
    <text class="title" x="28" y="44">Recommendations</text>

    <!-- Existing recommendations list -->
    <g transform="translate(36,80)">
      <text class="item" x="0" y="0">• Use HTTPS for all endpoints</text>
      <text class="item" x="0" y="36">• Optimize images (compression & responsive)</text>
      <text class="item" x="0" y="72">• Enable server-side caching</text>

      <!-- New recommendation being added -->
      <g transform="translate(0,120)">
        <rect class="badge" x="-22" y="-18" width="160" height="34" rx="6"/>
        <text class="new" x="0" y="0">+ New: Improve accessibility (ARIA labels)</text>
      </g>

      <!-- Arrow/annotation showing it's appended -->
      <g transform="translate(360,112)">
        <path d="M0 0 L120 -72" stroke="#0ea5a4" stroke-width="3" fill="none" marker-end="url(#arrow)"/>
      </g>
    </g>

    <defs>
      <marker id="arrow" markerWidth="10" markerHeight="10" refX="0" refY="3" orient="auto">
        <path d="M0,0 L0,6 L6,3 z" fill="#0ea5a4" />
      </marker>
    </defs>

    <text x="28" y="380" font-family="Segoe UI, Roboto, sans-serif" font-size="12" fill="#475569">This image demonstrates that a newly provided recommendation is appended to the existing list.</text>
  </g>
</svg>